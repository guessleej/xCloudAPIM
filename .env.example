# ═══════════════════════════════════════════════════════════════
#  xCloudAPIM — 環境變數範本
#  複製此檔案為 .env，填入實際值後啟動服務
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── 環境 ────────────────────────────────────────────────────
NODE_ENV=development
GO_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=apim
POSTGRES_USER=apim_user
POSTGRES_PASSWORD=local_postgres_password_change_me
POSTGRES_MAX_CONNS=20
POSTGRES_SSL_MODE=disable

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=local_redis_password_change_me
REDIS_DB=0
REDIS_CLUSTER_ENABLED=false

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=apim_analytics
MONGO_USER=apim_user
MONGO_PASSWORD=local_mongo_password_change_me
MONGO_URI=mongodb://apim_user:local_mongo_password_change_me@mongodb:27017/apim_analytics

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=apim
KAFKA_GROUP_ID=apim-consumers
KAFKA_TOPIC_API_REQUESTS=api.requests
KAFKA_TOPIC_API_ERRORS=api.errors
KAFKA_TOPIC_QUOTA_EXCEEDED=quota.exceeded

# ─── HashiCorp Vault ──────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=local_vault_token_change_me
VAULT_MOUNT_PKI=pki
VAULT_MOUNT_KV=secret
VAULT_JWT_KEY_PATH=secret/data/jwt

# ─── API Gateway ─────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_LOG_LEVEL=info
GATEWAY_MAX_BODY_SIZE=10mb
GATEWAY_REQUEST_TIMEOUT_MS=30000
GATEWAY_UPSTREAM_TIMEOUT_MS=25000

# ─── Auth Service ─────────────────────────────────────────────
AUTH_SERVICE_PORT=8081
AUTH_SERVICE_GRPC_PORT=9081
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400
JWT_ISSUER=https://auth.xcloudapim.local

# ─── API Registry Service ────────────────────────────────────
REGISTRY_SERVICE_PORT=8082
REGISTRY_SERVICE_GRPC_PORT=9082

# ─── Policy Engine ───────────────────────────────────────────
POLICY_ENGINE_PORT=8083
POLICY_ENGINE_GRPC_PORT=50051
POLICY_CACHE_TTL_SECONDS=60

# ─── Subscription Service ────────────────────────────────────
SUBSCRIPTION_SERVICE_PORT=8084
SUBSCRIPTION_SERVICE_GRPC_PORT=9084

# ─── Analytics Service ───────────────────────────────────────
ANALYTICS_SERVICE_PORT=8085
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL_MS=1000

# ─── Notification Service ────────────────────────────────────
NOTIFICATION_SERVICE_PORT=8086
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@xcloudapim.local

# ─── BFF GraphQL ─────────────────────────────────────────────
BFF_PORT=4000
BFF_GRAPHQL_PATH=/graphql
BFF_WS_PATH=/subscriptions
BFF_CORS_ORIGINS=http://localhost:5173,http://localhost:3001
BFF_URL=http://localhost:14000/graphql
GRAPHQL_MAX_COMPLEXITY=200

# ─── Policy Studio UI ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000
VITE_GRAPHQL_URL=http://localhost:4000/graphql
VITE_WS_URL=ws://localhost:4000/subscriptions

# ─── Developer Portal ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:18090
NEXTAUTH_URL=http://localhost:19000
NEXTAUTH_SECRET=local_nextauth_secret_min_32_chars
NEXTAUTH_PROVIDER_CLIENT_ID=portal-client
NEXTAUTH_PROVIDER_CLIENT_SECRET=local_provider_client_secret_change_me
NEXTAUTH_PROVIDER_ISSUER=http://localhost:8081

# ─── Observability ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=xcloudapim
PROMETHEUS_PORT=9464
LOG_FORMAT=json

# ─── Build metadata（Makefile / CI 自動填入）─────────────────
BUILD_DATE=
GIT_COMMIT=
IMAGE_TAG=latest

# ─── JWT / Session（須為 32 字元以上）──────────────────────
JWT_SECRET=change-me-jwt-secret-min-32-chars!!
SESSION_SECRET=change-me-session-secret-32chars!!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
OAUTH2_ISSUER=http://localhost/api/auth

# ─── Vault（dev mode）────────────────────────────────────────
VAULT_DEV_ROOT_TOKEN_ID=local_vault_token_change_me

# ─── Elasticsearch ────────────────────────────────────────────
ELASTIC_PASSWORD=local_elastic_password_change_me
KIBANA_PASSWORD=local_kibana_password_change_me
KIBANA_ENCRYPTION_KEY=local_kibana_encryption_key_min_32_chars

# ─── Grafana ──────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=local_grafana_password_change_me

# ─── pgAdmin ──────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@apim.local
PGADMIN_DEFAULT_PASSWORD=local_pgadmin_password_change_me

# ─── K6 / InfluxDB ────────────────────────────────────────────
INFLUXDB_K6_PASSWORD=local_influxdb_k6_password_change_me
INFLUXDB_K6_ADMIN_TOKEN=local_k6_admin_token_change_me

# ─── Public URLs（Nginx 對外）────────────────────────────────
PORTAL_URL=http://localhost:19000
GATEWAY_PUBLIC_URL=http://localhost:18090

# ─── 管理介面統一鑑權（Nginx Basic Auth / Kafka UI / Mongo Express）────
# 首次設定：MGMT_ADMIN_PASSWORD=yourpassword bash scripts/gen-htpasswd.sh
MGMT_ADMIN_USER=admin
MGMT_ADMIN_PASSWORD=local_mgmt_password_change_me

# ─── 服務間內部 Token（SEC-05）─────────────────────────────────
# 至少 32 字元隨機字串，各服務均須相同
INTERNAL_SERVICE_SECRET=change-me-internal-secret-min-32ch
