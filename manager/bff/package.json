{
  "name": "@xcloudapim/bff",
  "version": "1.0.0",
  "description": "xCloudAPIM BFF — Apollo Server 4 + GraphQL",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build":     "tsc -p tsconfig.json",
    "start":     "node --enable-source-maps dist/app.js",
    "dev":       "tsx watch src/app.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/server":          "^5.5.0",
    "body-parser":             "^1.20.3",
    "cors":                    "^2.8.5",
    "dataloader":              "^2.2.2",
    "express":                 "^4.19.2",
    "graphql":                 "^16.8.1",
    "graphql-tag":             "^2.12.6",
    "jose":                    "^5.3.0",
    "pino":                    "^9.1.0",
    "pino-pretty":             "^11.0.0",
    "undici":                  "^6.15.0",
    "zod":                     "^3.23.8"
  },
  "devDependencies": {
    "@types/cors":             "^2.8.17",
    "@types/express":          "^4.17.21",
    "@types/node":             "^20.12.0",
    "tsx":                     "^4.10.5",
    "typescript":              "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
