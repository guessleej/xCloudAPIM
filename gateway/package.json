{
  "name": "@xcloudapim/gateway",
  "version": "1.0.0",
  "description": "xCloudAPIM API Gateway — Fastify v4 + Node.js 20",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/app.js",
    "dev": "tsx watch src/app.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/reply-from": "^12.6.2",
    "@fastify/under-pressure": "^9.0.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.46.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.1",
    "@opentelemetry/sdk-node": "^0.51.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.3.2",
    "jose": "^5.3.0",
    "pino": "^9.1.0",
    "prom-client": "^15.1.2",
    "undici": "^6.15.0",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
