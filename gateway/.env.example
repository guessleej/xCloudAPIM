# ─── Server ───────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass_dev
REDIS_DB=0

# ─── Upstream Services ────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8081
REGISTRY_SERVICE_URL=http://localhost:8082
SUBSCRIPTION_SERVICE_URL=http://localhost:8084
POLICY_ENGINE_URL=http://localhost:8083

# ─── JWKS ─────────────────────────────────────────────────────
JWKS_URL=http://localhost:8081/oauth2/jwks
JWKS_CACHE_TTL_MS=300000

# ─── Route Table ──────────────────────────────────────────────
ROUTE_REFRESH_INTERVAL_MS=30000
ROUTE_CACHE_TTL_S=300

# ─── Proxy ────────────────────────────────────────────────────
PROXY_TIMEOUT_MS=30000
PROXY_KEEP_ALIVE_TIMEOUT_MS=60000
MAX_BODY_SIZE_MB=10

# ─── OpenTelemetry ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=api-gateway
