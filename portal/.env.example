# BFF GraphQL endpoint (server-side)
BFF_URL=http://localhost:4000/graphql

# Cookie secret for JWT signing (min 32 chars)
SESSION_SECRET=change-me-in-production-use-long-random-string

# Public URL (used in OG tags, canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Portal display name
NEXT_PUBLIC_SITE_NAME=xCloudAPIM Developer Portal

# API Gateway public URL (shown in code examples)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8090

# Registry Service (server-side, for spec proxy)
REGISTRY_SERVICE_URL=http://localhost:8082
