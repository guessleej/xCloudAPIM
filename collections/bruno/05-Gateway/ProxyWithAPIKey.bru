meta {
  name: Proxy Request (API Key Auth)
  type: http
  seq: 2
}

get {
  url: {{gateway_url}}/petstore/v1/pets
  body: none
  auth: none
}

headers {
  X-API-Key: {{api_key}}
  Accept: application/json
}

tests {
  test("not 401 or 403", function() {
    expect([401, 403]).to.not.include(res.status);
  });
}
