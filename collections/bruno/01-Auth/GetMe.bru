meta {
  name: Get Me
  type: http
  seq: 5
}

get {
  url: {{auth_url}}/api/v1/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("has email", function() {
    expect(res.body.data.email).to.be.a("string");
  });
}
