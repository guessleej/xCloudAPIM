{
  "__inputs": [
    { "name": "DS_INFLUXDB_K6", "label": "InfluxDB-K6", "type": "datasource", "pluginId": "influxdb" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" }
  ],
  "description": "K6 Load Test Results — VUs, RPS, Latency, Error Rate",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 50 },
          { "color": "red", "value": 100 }
        ]}, "unit": "short" }},
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Active VUs",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_vus\" and r._field == \"value\") |> last()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.01 },
          { "color": "red", "value": 0.05 }
        ]}, "unit": "percentunit" }},
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "background" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_req_failed\" and r._field == \"value\") |> mean()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 500 },
          { "color": "red", "value": 1000 }
        ]}, "unit": "ms" }},
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "background" },
      "title": "P95 Duration",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_req_duration\" and r._field == \"p95\") |> mean()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "value" },
      "title": "Avg RPS",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_reqs\" and r._field == \"count\") |> derivative(unit: 1s, nonNegative: true) |> mean()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" },
        "custom": { "lineWidth": 2 } }},
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Virtual Users Over Time",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_vus\" and r._field == \"value\") |> aggregateWindow(every: 10s, fn: mean)",
        "legendFormat": "VUs",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" },
        "custom": { "lineWidth": 2 } }},
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Duration Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
          "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_req_duration\" and r._field == \"p50\") |> aggregateWindow(every: 10s, fn: mean)",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
          "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_req_duration\" and r._field == \"p95\") |> aggregateWindow(every: 10s, fn: mean)",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
          "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_req_duration\" and r._field == \"p99\") |> aggregateWindow(every: 10s, fn: mean)",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" },
        "custom": { "lineWidth": 2 } }},
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_req_failed\" and r._field == \"value\") |> aggregateWindow(every: 10s, fn: mean)",
        "legendFormat": "Error Rate",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" },
        "custom": { "lineWidth": 2 } }},
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "title": "Throughput (RPS) by Scenario",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "from(bucket:\"k6\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r) => r._measurement == \"k6_http_reqs\" and r._field == \"count\") |> aggregateWindow(every: 10s, fn: sum) |> map(fn:(r) => ({r with _value: float(v: r._value) / 10.0}))",
        "legendFormat": "RPS",
        "refId": "A"
      }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["k6", "load-test", "apim"],
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "title": "K6 Load Test Results",
  "uid": "apim-k6-results",
  "version": 1
}
